# MongoDB Atlas Connection String
# Get this from: https://www.mongodb.com/products/platform/cloud
# Format: mongodb://username:password@host1:27017,host2:27017,host3:27017/dbname?options

MONGODB_URI=mongodb://YOUR_USERNAME:YOUR_PASSWORD@YOUR_CLUSTER.mongodb.net/offerbridge?ssl=true&replicaSet=YOUR_REPLICASET&authSource=admin
NEXT_PUBLIC_MONGODB_URI=mongodb://YOUR_USERNAME:YOUR_PASSWORD@YOUR_CLUSTER.mongodb.net/offerbridge?ssl=true&replicaSet=YOUR_REPLICASET&authSource=admin

# NextAuth Configuration
# Generate NEXTAUTH_SECRET: openssl rand -base64 32
NEXTAUTH_SECRET=your-random-secret-key-here
NEXTAUTH_URL=http://localhost:3000

# OAuth Providers
# ============================================
# GOOGLE OAUTH
# Setup: https://console.cloud.google.com/
# Create OAuth 2.0 credentials (Web application)
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# FACEBOOK OAUTH
# Setup: https://developers.facebook.com/apps
# Create App > Facebook Login
# Authorized redirect URI: http://localhost:3000/api/auth/callback/facebook
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret

# MICROSOFT AD / AZURE
# Setup: https://portal.azure.com/ (Azure AD > App registrations)
# Create new registration
# Authorized redirect URI: http://localhost:3000/api/auth/callback/azure-ad
AZURE_AD_CLIENT_ID=your-azure-client-id
AZURE_AD_CLIENT_SECRET=your-azure-client-secret
AZURE_AD_TENANT_ID=your-azure-tenant-id

# Node Environment (set by deployment platform)
# NODE_ENV=production
