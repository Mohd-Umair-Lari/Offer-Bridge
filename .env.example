# MongoDB Atlas Connection String
# Get this from: https://www.mongodb.com/products/platform/cloud
# Format: mongodb://username:password@host1:27017,host2:27017,host3:27017/dbname?options

MONGODB_URI=mongodb://YOUR_USERNAME:YOUR_PASSWORD@YOUR_CLUSTER.mongodb.net/offerbridge?ssl=true&replicaSet=YOUR_REPLICASET&authSource=admin
NEXT_PUBLIC_MONGODB_URI=mongodb://YOUR_USERNAME:YOUR_PASSWORD@YOUR_CLUSTER.mongodb.net/offerbridge?ssl=true&replicaSet=YOUR_REPLICASET&authSource=admin

# Node Environment (set by deployment platform)
# NODE_ENV=production

# Optional: API Keys (for future integrations)
# STRIPE_API_KEY=
# NEXTAUTH_SECRET=random-string-for-jwt
# NEXTAUTH_URL=https://yourdomain.com
